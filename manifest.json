{
  "manifest_version": 3,
  "name": "Pluck",
  "version": "1.0.0",
  "description": "Pluck content from any page and think with it — lightweight AI sidebar for the curious browser.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "tabs",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.deepseek.com/*",
    "https://api.anthropic.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "options_page": "src/options.html",
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Pluck",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "commands": {
    "open-sidebar-capture": {
      "suggested_key": { "default": "Alt+1" },
      "description": "Open Pluck sidebar and capture context"
    },
    "toggle-sidebar": {
      "suggested_key": { "default": "Alt+K" },
      "description": "Toggle Pluck sidebar open/closed"
    },
    "find-on-page": {
      "suggested_key": { "default": "Alt+S" },
      "description": "Open floating find panel with AI fallback"
    }
  }
}
